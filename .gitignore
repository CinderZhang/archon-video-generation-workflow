# Secrets / env
.env
.env.local
.env.*.local

# Archon runtime artifacts (may reference env vars, never commit)
.archon/mcp/

# Local Claude Code state (keep project skills, ignore per-user settings)
.claude/settings.local.json
.claude/settings.local.md

# Dependencies
node_modules/
.pnpm-store/

# Build / output
dist/
build/
out/
*.log

# Python bytecode (from .archon/scripts/*.py)
__pycache__/
*.pyc

# Workflow video archive — per-run mp4s + artifacts under ./videos/<date>-<slug>/.
# Remove this line if you want to track renders in git.
videos/

# Generated audio assets (voiceover, music, SFX) accumulated by workflow runs.
# These are large binaries tied to API calls — regenerate from runs if lost.
# Remove these lines if you want to track the audio library in git.
public/voiceover/
public/music/
public/sfx/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
